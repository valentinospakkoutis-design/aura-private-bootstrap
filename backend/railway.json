{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "uvicorn backend.main:app --host 0.0.0.0 --port $PORT",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  },
  "crons": [
    {
      "schedule": "0 6 * * *",
      "command": "python backend/cron_runner.py fetch_news"
    },
    {
      "schedule": "30 0 * * *",
      "command": "python backend/cron_runner.py fear_greed"
    },
    {
      "schedule": "0 3 * * 0",
      "command": "python backend/cron_runner.py weekly_retrain"
    },
    {
      "schedule": "0 2 1 * *",
      "command": "python backend/cron_runner.py monthly_rl"
    }
  ]
}
