{
  "name": "aura-private-bootstrap",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "commit": "powershell -ExecutionPolicy Bypass -File ./scripts/auto-commit.ps1",
    "commit:push": "powershell -ExecutionPolicy Bypass -File ./scripts/auto-commit.ps1 -Push",
    "analyze": "npx expo export --platform web && npx source-map-explorer dist/*.js --html bundle-analysis.html",
    "build:android:preview": "eas build --platform android --profile preview",
    "build:android:production": "eas build --platform android --profile production",
    "build:android:standalone": "eas build --platform android --profile standalone",
    "build:android:dev": "eas build --platform android --profile development",
    "build:status": "eas build:list",
    "build:download": "eas build:download",
    "test:endpoints": "node scripts/test-endpoints.js",
    "test:endpoints:prod": "API_URL=https://your-railway-url.railway.app node scripts/test-endpoints.js",
    "fix:imports": "node scripts/fix-imports.js"
  },
  "dependencies": {
    "@expo/metro-runtime": "~5.0.5",
    "@react-native-async-storage/async-storage": "2.1.2",
    "@react-native-community/netinfo": "^11.4.1",
    "@react-native-community/slider": "4.5.6",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@tamagui/core": "^1.112.23",
    "axios": "^1.13.2",
    "expo": "^53.0.0",
    "expo-analytics": "^1.0.0",
    "expo-application": "~6.1.5",
    "expo-asset": "~11.1.7",
    "expo-audio": "~0.4.9",
    "expo-av": "~15.1.7",
    "expo-blur": "~14.1.5",
    "expo-build-properties": "~0.14.8",
    "expo-clipboard": "~7.1.5",
    "expo-constants": "~17.1.8",
    "expo-crypto": "~14.1.5",
    "expo-dev-client": "~5.2.4",
    "expo-device": "~7.1.4",
    "expo-file-system": "~18.1.11",
    "expo-gl": "~15.1.7",
    "expo-haptics": "~14.1.4",
    "expo-image-picker": "~16.1.4",
    "expo-linear-gradient": "~14.1.5",
    "expo-linking": "~7.1.7",
    "expo-local-authentication": "~16.0.5",
    "expo-notifications": "~0.31.5",
    "expo-router": "~5.1.11",
    "expo-secure-store": "~14.2.4",
    "expo-splash-screen": "~0.30.10",
    "expo-status-bar": "~2.2.3",
    "expo-updates": "~0.28.18",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-native": "0.79.6",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-reanimated": "~3.17.4",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-web": "^0.20.0",
    "sentry-expo": "~7.0.0",
    "sharp-cli": "^5.2.0",
    "three": "^0.169.0",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@react-native-community/cli": "^20.0.2",
    "@types/react": "~19.0.10",
    "@types/react-native": "^0.72.8",
    "@types/three": "^0.169.0",
    "babel-plugin-module-resolver": "^5.0.2"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "expo-av",
          "@react-three/drei",
          "@react-three/fiber",
          "@tamagui/core",
          "three"
        ],
        "listUnknownPackages": false
      }
    }
  },
  "private": true
}
